DATABASE_URL=sqlite:///./backend/dev.db
APP_SESSION_SECRET=replace-me
PLAYBACK_TOKEN_SECRET=replace-me
AUTH_INVITE_CODE=replace-me
AUTH_MAX_USERS=2
COOKIE_SECURE=false
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://127.0.0.1:5173,http://127.0.0.1:5174
TIDAL_QUALITY=HIGH

# Cloudflare R2 (optional — local files fall back to IndexedDB blobs if not set)
R2_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=sauti-sounds
R2_PUBLIC_URL=
